# --- providers ---
FRAME_PROVIDER=mock
HID_BRIDGE=esp32_http

# --- OBS WebSocket ---
OBS_WS_URL=ws://localhost:4455
OBS_WS_PASSWORD=
OBS_SOURCE_NAME=VDI Capture

# --- ESP32 ---
ESP32_BASE_URL=http://192.168.31.234
ESP32_WS_URL=ws://192.168.31.234:81/hid
ESP32_API_TOKEN=change-me

# --- VDI ---
VDI_WIDTH=3840
VDI_HEIGHT=2160

# --- timings (ms) ---
FRAME_REFRESH_INTERVAL_MS=1000
AFTER_ACTION_REFRESH_DELAY_MS=500
STALE_FRAME_WARNING_MS=5000
STALE_FRAME_BLOCK_MS=15000
HID_COMMAND_TIMEOUT_MS=5000

# --- storage ---
FRAME_STORAGE_DIR=./data/frames

# --- security ---
WORK_AGENT_CORS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
